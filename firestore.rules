rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function checkUserRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().get('role', '') == role;
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'dragonballsam86@gmail.com' ||
        request.auth.token.role == 'admin' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          getUserData().get('isAdmin', false) == true ||
          getUserData().get('role', '') == 'admin'
        ))
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid)) ||
        checkUserRole('waiter') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isWaiter', false) == true)
      );
    }
    
    function isKitchen() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)) ||
        checkUserRole('kitchen') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isKitchen', false) == true)
      );
    }
    
    function isBarman() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/barman/$(request.auth.uid)) ||
        checkUserRole('barman') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isBarman', false) == true)
      );
    }
    
    function isDriver() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid)) ||
        checkUserRole('driver') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isDriver', false) == true)
      );
    }
    
    function isCashier() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/cashiers/$(request.auth.uid)) ||
        checkUserRole('cashier') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isCashier', false) == true)
      );
    }
    
    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        isWaiter() || 
        isKitchen() || 
        isBarman() || 
        isDriver() || 
        isCashier() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().get('isStaff', false) == true)
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             (data.get('points', 0) is number) &&
             (data.get('email', '') is string) &&
             (data.get('role', '') is string) &&
             (data.get('coffeeCount', 0) is number);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      
      // Fully relaxed for dev owners
      allow create, update: if isOwner(userId);
      
      allow update: if isStaff() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty']);
      allow delete: if isAdmin();
    }

    // --- Role Collections ---
    match /admins/{id} { 
      allow read: if isSignedIn(); 
      // Only existing admins or the system creator can nominate new admins
      allow write: if isAdmin(); 
    }
    match /waiters/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /kitchen/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /barman/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /drivers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /cashiers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin() || isCashier()) &&
             data.total is number &&
             data.items is list &&
             (data.status == 'pending' || data.status == 'accepted' || ((isAdmin() || isCashier()) && data.status == 'delivered'));
    }

    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      
      allow update: if isStaff() && (
        // Case 1: Order is unassigned - any staff can assign themselves
        existing().get('waiterId', null) == null || 
        // Case 2: Order is already assigned to the current user
        existing().get('waiterId', null) == request.auth.uid ||
        // Case 3: Admin override
        isAdmin()
      );
      
      // Allow drivers to update delivery status
      allow update: if isSignedIn() && isDriver() && existing().get('deliveryType', '') == 'delivery' && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
                    
      allow delete: if isAdmin();
    }

    // --- Daily Revenue & Stats ---
    match /dailyRevenue/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /weeklyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /monthlyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Waiter Requests ---
    function isValidWaiterRequest(data) {
      return (data.clientId == request.auth.uid || isWaiter() || isAdmin()) &&
             data.fullTableLabel is string &&
             data.status in ['new', 'accepted', 'completed'];
    }

    match /waiterRequests/{requestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidWaiterRequest(incoming());
      allow update: if isStaff() && (
        // Unassigned or assigned to self or admin
        existing().get('waiterId', null) == null || 
        existing().get('waiterId', null) == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Staff Configs ---
    match /staffConfigs/{id} {
      // Allow get so staff can verify credentials without listing the whole collection
      allow get: if true; 
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
