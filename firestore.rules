rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Check if the current user is recorded in the 'admins' collection
    // Or if they are the primary developer email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.get('email', '') == 'dragonballsam86@gmail.com')
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isWaiter', false) == true)
      );
    }
    
    function isKitchen() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isKitchen', false) == true)
      );
    }
    
    function isBarman() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/barman/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBarman', false) == true)
      );
    }
    
    function isDriver() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDriver', false) == true)
      );
    }
    
    function isCashier() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/cashiers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isCashier', false) == true)
      );
    }
    
    function isStaff() {
      return isAdmin() || isWaiter() || isKitchen() || isBarman() || isDriver() || isCashier();
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.points is number &&
             (data.get('email', '') is string) &&
             (data.get('coffeeCount', 0) is number) &&
             (data.get('isWaiter', false) is bool) &&
             (data.get('isKitchen', false) is bool) &&
             (data.get('isBarman', false) is bool) &&
             (data.get('isCashier', false) is bool) &&
             (data.get('isDriver', false) is bool) &&
             (data.get('isAdmin', false) is bool) &&
             (data.get('createdAt', request.time) is timestamp);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isStaff());
      allow list: if isSignedIn() && isStaff(); 
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'itemLoyalty', 'coffeeCount', 'points', 'isWaiter', 'isKitchen', 'isBarman', 'isDriver', 'isCashier', 'address', 'email', 'createdAt'])
      ) || (
        isStaff() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty'])
      );
      allow delete: if isAdmin();
    }

    // --- Role Collections ---
    match /admins/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /waiters/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSignedIn() && id == request.auth.uid); }
    match /kitchen/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSignedIn() && id == request.auth.uid); }
    match /barman/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSignedIn() && id == request.auth.uid); }
    match /drivers/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSignedIn() && id == request.auth.uid); }
    match /cashiers/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || (isSignedIn() && id == request.auth.uid); }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin() || isCashier()) &&
             data.total is number &&
             data.items is list &&
             (data.status == 'pending' || data.status == 'accepted');
    }

    match /orders/{orderId} {
      allow read: if isStaff() || (isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isDriver() && resource.data.get('deliveryType', '') == 'delivery')
      ));
      
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && (isValidOrder(incoming()) || isAdmin());
      
      allow update: if isStaff();
      // Allow drivers to update delivery status
      allow update: if isSignedIn() && isDriver() && existing().get('deliveryType', '') == 'delivery' && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
                    
      allow delete: if isAdmin();
    }

    // --- Daily Revenue & Stats ---
    match /dailyRevenue/{date} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (isStaff() || (incoming().keys().hasAll(['amount', 'lastUpdated']) && incoming().amount >= 0));
      allow update: if isSignedIn() && (isStaff() || (incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'lastUpdated', 'orderCount']) && incoming().amount >= existing().amount));
      allow delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isAdmin() || isCashier();
      allow write: if isAdmin() || isCashier();
    }
  }
}
