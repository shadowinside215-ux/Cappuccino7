rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Check if the current user is recorded in the 'admins' collection
    // Or if they are the primary developer email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email.lower() == 'dragonballsam86@gmail.com'
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.points is number;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isAdmin() || (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'itemLoyalty', 'coffeeCount', 'points'])
      );
    }

    // --- Admin List ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.total is number &&
             data.items is list &&
             data.status == 'pending';
    }

    match /orders/{orderId} {
      // List permission:
      // 1. Admins see all.
      // 2. Regular users see their own (requires where('userId', '==', uid) in query).
      // 3. Drivers see delivery orders (requires where('deliveryType', '==', 'delivery') in query).
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid) || 
        (resource.data.deliveryType == 'delivery')
      );
      
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        resource.data.deliveryType == 'delivery'
      );
      
      allow create: if isSignedIn() && (isValidOrder(incoming()) || isAdmin());
      
      allow update: if isAdmin() || (isSignedIn() && existing().deliveryType == 'delivery');
      allow delete: if isAdmin();
    }
  }
}
