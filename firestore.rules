rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isSpecificAdminEmail() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)dragonballsam86@gmail.com') ||
        request.auth.token.email.matches('(?i)client@example.com')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSpecificAdminEmail() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    incoming().points == 0 && 
                    (incoming().isAdmin == false || isSpecificAdminEmail());
      allow update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'points', 'itemLoyalty', 'coffeeCount', 'isAdmin']);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSpecificAdminEmail() || (isAdmin() && adminId == request.auth.uid);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.categoryId is string &&
             (data.image == null || (data.image is string && data.image.size() < 1000)) &&
             (data.description == null || (data.description is string && data.description.size() < 500)) &&
             (data.isAvailable == null || data.isAvailable is bool);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && (
        // Check if the resulting document is valid
        isValidProduct(request.resource.data) &&
        // And only allowed fields are being touched
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'categoryId', 'image', 'isAvailable'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending' && request.resource.data.status == 'cancelled' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
