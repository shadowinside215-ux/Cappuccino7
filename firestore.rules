rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Check if the current user is recorded in the 'admins' collection
    // Or if they are the primary developer email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.get('email', '') == 'dragonballsam86@gmail.com')
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isWaiter', false) == true)
      );
    }
    
    function isKitchen() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isKitchen', false) == true)
      );
    }
    
    function isBarman() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/barman/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBarman', false) == true)
      );
    }
    
    function isDriver() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDriver', false) == true)
      );
    }
    
    function isStaff() {
      return isAdmin() || isWaiter() || isKitchen() || isBarman();
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.points is number &&
             (data.get('isWaiter', false) is bool) &&
             (data.get('isKitchen', false) is bool) &&
             (data.get('isBarman', false) is bool);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isWaiter() || isKitchen() || isBarman() || isDriver());
      allow list: if isSignedIn() && (isAdmin() || isWaiter() || isKitchen() || isBarman() || isDriver()); 
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'itemLoyalty', 'coffeeCount', 'points', 'isWaiter', 'isKitchen', 'isBarman', 'address'])
      ) || (
        (isWaiter() || isKitchen() || isBarman()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty'])
      );
      allow delete: if isAdmin();
    }

    // --- Admin List ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Allow self-registration if they provide the correct bootstrap secret
      allow create: if isSignedIn() && adminId == request.auth.uid && (
        incoming().get('secret_key', '') == 'admin2000' || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // --- Waiter List ---
    match /waiters/{waiterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Kitchen List ---
    match /kitchen/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && staffId == request.auth.uid);
    }

    // --- Barman List ---
    match /barman/{staffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && staffId == request.auth.uid);
    }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin()) &&
             data.total is number &&
             data.items is list &&
             data.status == 'pending';
    }

    match /orders/{orderId} {
      // Staff can see all orders
      allow list: if isStaff();
      
      // Customers see their own, Drivers see deliveries
      allow list: if isSignedIn() && (
        (resource == null) ||
        (resource.data.userId == request.auth.uid) ||
        (isDriver() && resource.data.get('deliveryType', '') == 'delivery')
      );
      
      // Get permission
      allow get: if isStaff() || (isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isDriver() && resource.data.get('deliveryType', '') == 'delivery')
      ));
      
      allow create: if isSignedIn() && (isValidOrder(incoming()) || isAdmin());
      
      allow update: if isStaff();
      // Allow drivers to update delivery status
      allow update: if isSignedIn() && isDriver() && existing().get('deliveryType', '') == 'delivery' && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
                    
      allow delete: if isAdmin();
    }

    // --- Daily Revenue ---
    match /dailyRevenue/{date} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && (
        isAdmin() || 
        isWaiter() ||
        (incoming().keys().hasAll(['amount', 'lastUpdated']) && incoming().amount >= 0)
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        isWaiter() ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'lastUpdated', 'orderCount']) && 
         incoming().amount >= existing().amount)
      );
      allow delete: if isAdmin();
    }
  }
}
