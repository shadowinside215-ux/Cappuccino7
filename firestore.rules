rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Check if the current user is recorded in the 'admins' collection
    // Or if they are the primary developer email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'dragonballsam86@gmail.com' && request.auth.token.email_verified == true)
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isWaiter', false) == true)
      );
    }
    
    function isKitchen() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isKitchen', false) == true)
      );
    }
    
    function isBarman() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/barman/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBarman', false) == true)
      );
    }
    
    function isDriver() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDriver', false) == true)
      );
    }
    
    function isCashier() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/cashiers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isCashier', false) == true)
      );
    }
    
    function isStaff() {
      return isAdmin() || isWaiter() || isKitchen() || isBarman() || isDriver() || isCashier();
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             data.points is number &&
             (data.get('email', '') is string) &&
             (data.get('coffeeCount', 0) is number) &&
             (data.get('createdAt', request.time) is timestamp || data.get('createdAt', '') is string);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isStaff());
      allow list: if isSignedIn() && isStaff(); 
      
      // Prevent normal users from creating accounts with staff/admin privileges
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().get('isAdmin', false) == false &&
                    incoming().get('isWaiter', false) == false &&
                    incoming().get('isKitchen', false) == false &&
                    incoming().get('isBarman', false) == false &&
                    incoming().get('isCashier', false) == false &&
                    incoming().get('isStaff', false) == false;

      allow update: if isAdmin() || (
        isSignedIn() && isOwner(userId) && 
        // Prevent self-elevation of privileges
        !incoming().diff(existing()).affectedKeys().hasAny(['isAdmin', 'isStaff', 'isWaiter', 'isKitchen', 'isBarman', 'isDriver', 'isCashier']) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'itemLoyalty', 'coffeeCount', 'points', 'address', 'email', 'updatedAt'])
      ) || (
        isStaff() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty'])
      );
      allow delete: if isAdmin();
    }

    // --- Role Collections ---
    match /admins/{id} { 
      allow read: if isSignedIn(); 
      // Only existing admins or the system creator can nominate new admins
      allow write: if isAdmin(); 
    }
    match /waiters/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /kitchen/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /barman/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /drivers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /cashiers/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin() || isCashier()) &&
             data.total is number &&
             data.items is list &&
             (data.status == 'pending' || data.status == 'accepted' || ((isAdmin() || isCashier()) && data.status == 'delivered'));
    }

    match /orders/{orderId} {
      allow read: if isStaff() || (isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (isDriver() && resource.data.get('deliveryType', '') == 'delivery')
      ));
      
      allow list: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && (isValidOrder(incoming()) || isAdmin());
      
      allow update: if isStaff();
      // Allow drivers to update delivery status
      allow update: if isSignedIn() && isDriver() && existing().get('deliveryType', '') == 'delivery' && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
                    
      allow delete: if isAdmin();
    }

    // --- Daily Revenue & Stats ---
    match /dailyRevenue/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /weeklyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /monthlyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Waiter Requests ---
    function isValidWaiterRequest(data) {
      return (data.clientId == request.auth.uid || isWaiter() || isAdmin()) &&
             data.fullTableLabel is string &&
             data.status in ['new', 'accepted', 'completed'];
    }

    match /waiterRequests/{requestId} {
      allow read, list: if isStaff() || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && isValidWaiterRequest(incoming());
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Staff Configs ---
    match /staffConfigs/{id} {
      // Allow get so staff can verify credentials without listing the whole collection
      allow get: if true; 
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
