rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read: if false;
      allow write: if false;
      allow delete: if isAdmin();
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        request.auth.token.email == 'dragonballsam86@gmail.com' ||
        (hasUser && (userData.get('isAdmin', false) == true || userData.get('role', '') == 'admin')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isWaiter', false) == true || userData.get('role', '') == 'waiter')) || 
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid))
      );
    }
    
    function isKitchen() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isKitchen', false) == true || userData.get('role', '') == 'kitchen')) || 
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid))
      );
    }
    
    function isBarman() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isBarman', false) == true || userData.get('role', '') == 'barman')) || 
        exists(/databases/$(database)/documents/barman/$(request.auth.uid))
      );
    }
    
    function isDriver() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isDriver', false) == true || userData.get('role', '') == 'driver')) || 
        exists(/databases/$(database)/documents/drivers/$(request.auth.uid))
      );
    }

    function isCashier() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isCashier', false) == true || userData.get('role', '') == 'cashier')) || 
        exists(/databases/$(database)/documents/cashiers/$(request.auth.uid))
      );
    }
    
    function isStaff() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let hasUser = isSignedIn() && exists(userPath);
      let userData = hasUser ? get(userPath).data : null;
      return isSignedIn() && (
        (hasUser && (userData.get('isStaff', false) == true || userData.get('role', '') in ['admin', 'waiter', 'kitchen', 'barman', 'cashier', 'driver'])) ||
        exists(/databases/$(database)/documents/waiters/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/barman/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/cashiers/$(request.auth.uid))
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             (data.get('points', 0) is number) &&
             (data.get('email', '') is string) &&
             (data.get('role', '') is string) &&
             (data.get('coffeeCount', 0) is number);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      
      // Fully relaxed for dev owners
      allow create, update: if isOwner(userId);
      
      allow update: if isStaff() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty']);
      allow delete: if isAdmin();
    }

    // --- Role Collections ---
    match /admins/{id} { 
      allow read: if isSignedIn(); 
      // Only existing admins or the system creator can nominate new admins
      allow write: if isAdmin(); 
    }
    match /waiters/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /kitchen/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /barman/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /drivers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /cashiers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin() || isCashier()) &&
             data.total is number &&
             data.items is list &&
             (data.status == 'pending' || data.status == 'accepted' || ((isAdmin() || isCashier()) && data.status == 'delivered'));
    }

    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      
      allow update: if (isOwner(existing().userId) && existing().status == 'pending' && 
        (!('createdAt' in existing()) || existing().createdAt == null || (request.time.toMillis() - existing().createdAt.toMillis() < 300000)) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'items', 'total', 'isModified', 'kitchenStatus', 'barmanStatus', 'deliveryType', 'tableZone', 'tableArea', 'tableNumber', 'fullTableLabel', 'prepTime', 'expectedReadyAt', 'address', 'deliveryNotes', 'customerName', 'customerPhone'])) ||
        (isStaff() && (
          // Action: Staff self-assignment (Take Order) - Relaxed hasAny for flexibility
          (existing().get('waiterId', null) == null && incoming().diff(existing()).affectedKeys().hasAny(['waiterId', 'waiterName', 'waiterStatus', 'status', 'updatedAt'])) ||
          
          // Action: Assigned staff updating status and timing metrics
          (existing().get('waiterId', null) == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['status', 'kitchenStatus', 'barmanStatus', 'isPaid', 'updatedAt', 'waiterStatus', 'deliveredAt', 'deliveredInMinutes', 'readyInMinutes', 'readyAt', 'preparingAt'])) ||
          
          // Action: Admin or Cashier updating payment or overall status
          ((isAdmin() || isCashier()) && incoming().diff(existing()).affectedKeys().hasAny(['isPaid', 'paymentMethod', 'status', 'updatedAt', 'deliveredAt', 'paidAt', 'waiterId', 'waiterName'])) ||
          
          // Action: Kitchen/Barman updating their specific status
          ((isKitchen() || isBarman() || isAdmin()) && incoming().diff(existing()).affectedKeys().hasAny(['kitchenStatus', 'barmanStatus', 'status', 'updatedAt', 'deliveredInMinutes', 'readyInMinutes', 'readyAt', 'preparingAt'])) ||
          
          // Action: Driver updating delivery status
          (isDriver() && existing().get('deliveryType', '') == 'delivery' && incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt', 'deliveredAt']))
        ));
      
      allow delete: if isAdmin();
    }

    // --- Daily Revenue & Stats ---
    match /dailyRevenue/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /weeklyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /monthlyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Waiter Requests ---
    function isValidWaiterRequest(data) {
      return (data.clientId == request.auth.uid || isWaiter() || isAdmin()) &&
             data.fullTableLabel is string &&
             data.status in ['new', 'accepted', 'completed'];
    }

    match /waiterRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidWaiterRequest(incoming());
      allow update: if isStaff() && (
        // Unassigned or assigned to self or admin
        existing().get('waiterId', null) == null || 
        existing().get('waiterId', null) == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Staff Configs ---
    match /staffConfigs/{id} {
      // Allow list and get so staff can verify credentials before full auth
      allow read: if true; 
      allow write: if isAdmin();
    }
  }
}
