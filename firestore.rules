rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() { 
      let data = getUserData();
      return isSignedIn() && (
        request.auth.token.email == 'dragonballsam86@gmail.com' ||
        request.auth.token.role == 'admin' ||
        data.get('isAdmin', false) == true ||
        data.get('role', '') == 'admin' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isWaiter() {
      let data = getUserData();
      return isSignedIn() && (data.get('isWaiter', false) == true || data.get('role', '') == 'waiter' || exists(/databases/$(database)/documents/waiters/$(request.auth.uid)));
    }
    
    function isKitchen() {
      let data = getUserData();
      return isSignedIn() && (data.get('isKitchen', false) == true || data.get('role', '') == 'kitchen' || exists(/databases/$(database)/documents/kitchen/$(request.auth.uid)));
    }
    
    function isBarman() {
      let data = getUserData();
      return isSignedIn() && (data.get('isBarman', false) == true || data.get('role', '') == 'barman' || exists(/databases/$(database)/documents/barman/$(request.auth.uid)));
    }
    
    function isDriver() {
      let data = getUserData();
      return isSignedIn() && (data.get('isDriver', false) == true || data.get('role', '') == 'driver' || exists(/databases/$(database)/documents/drivers/$(request.auth.uid)));
    }
    
    function isCashier() {
      let data = getUserData();
      return isSignedIn() && (data.get('isCashier', false) == true || data.get('role', '') == 'cashier' || exists(/databases/$(database)/documents/cashiers/$(request.auth.uid)));
    }
    
    function isStaff() {
      let data = getUserData();
      return isSignedIn() && (
        isAdmin() || 
        isWaiter() ||
        isKitchen() ||
        isBarman() ||
        isDriver() ||
        isCashier() ||
        data.get('isStaff', false) == true ||
        data.get('role', '') in ['admin', 'waiter', 'kitchen', 'barman', 'cashier', 'driver']
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string &&
             (data.get('points', 0) is number) &&
             (data.get('email', '') is string) &&
             (data.get('role', '') is string) &&
             (data.get('coffeeCount', 0) is number);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      
      // Fully relaxed for dev owners
      allow create, update: if isOwner(userId);
      
      allow update: if isStaff() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['points', 'coffeeCount', 'itemLoyalty']);
      allow delete: if isAdmin();
    }

    // --- Role Collections ---
    match /admins/{id} { 
      allow read: if isSignedIn(); 
      // Only existing admins or the system creator can nominate new admins
      allow write: if isAdmin(); 
    }
    match /waiters/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /kitchen/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /barman/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /drivers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }
    match /cashiers/{id} { allow read: if isSignedIn(); allow write: if isOwner(id) || isAdmin(); }

    // --- Settings (Brand, Global, etc.) ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Menu ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return (data.userId == request.auth.uid || isAdmin() || isCashier()) &&
             data.total is number &&
             data.items is list &&
             (data.status == 'pending' || data.status == 'accepted' || ((isAdmin() || isCashier()) && data.status == 'delivered'));
    }

    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      
      allow update: if isStaff() && (
        // Action: Staff self-assignment (Take Order)
        (existing().get('waiterId', null) == null && incoming().diff(existing()).affectedKeys().hasOnly(['waiterId', 'waiterName', 'waiterStatus', 'status', 'updatedAt'])) ||
        
        // Action: Assigned staff updating status
        (existing().get('waiterId', null) == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['status', 'kitchenStatus', 'barmanStatus', 'isPaid', 'updatedAt', 'waiterStatus', 'deliveredAt'])) ||
        
        // Action: Admin or Cashier updating payment or overall status
        ((isAdmin() || isCashier()) && incoming().diff(existing()).affectedKeys().hasOnly(['isPaid', 'paymentMethod', 'status', 'updatedAt', 'deliveredAt', 'paidAt'])) ||
        
        // Action: Kitchen/Barman updating their specific status
        ((isKitchen() || isBarman()) && incoming().diff(existing()).affectedKeys().hasOnly(['kitchenStatus', 'barmanStatus', 'status', 'updatedAt'])) ||
        
        // Action: Driver updating delivery status
        (isDriver() && existing().get('deliveryType', '') == 'delivery' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'deliveredAt']))
      );
      
      allow delete: if isAdmin();
    }

    // --- Daily Revenue & Stats ---
    match /dailyRevenue/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /weeklyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /monthlyRevenue/{id} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    match /stats/{date} {
      allow read: if isStaff();
      allow write: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Waiter Requests ---
    function isValidWaiterRequest(data) {
      return (data.clientId == request.auth.uid || isWaiter() || isAdmin()) &&
             data.fullTableLabel is string &&
             data.status in ['new', 'accepted', 'completed'];
    }

    match /waiterRequests/{requestId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidWaiterRequest(incoming());
      allow update: if isStaff() && (
        // Unassigned or assigned to self or admin
        existing().get('waiterId', null) == null || 
        existing().get('waiterId', null) == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Staff Configs ---
    match /staffConfigs/{id} {
      // Allow get so staff can verify credentials without listing the whole collection
      allow get: if true; 
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
