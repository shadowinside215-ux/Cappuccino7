{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and loyalty data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "points": { "type": "number" },
        "coffeeCount": { "type": "number" },
        "itemLoyalty": { "type": "object" },
        "isAdmin": { "type": "boolean" },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "points"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "BrandSettings": {
      "title": "Brand Settings",
      "description": "Global application branding",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "heroImageUrl": { "type": "string" },
        "cartBgUrl": { "type": "string" },
        "ordersBgUrl": { "type": "string" },
        "profileBgUrl": { "type": "string" },
        "loginBgUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and loyalty points"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer food and drink orders"
    },
    "/settings/brand": {
      "schema": "BrandSettings",
      "description": "Global brand configuration"
    },
    "/admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        }
      },
      "description": "List of admin UIDs"
    },
    "/categories/{categoryId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "order": { "type": "number" }
        }
      },
      "description": "Menu categories"
    },
    "/products/{productId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "imageUrl": { "type": "string" },
          "categoryId": { "type": "string" },
          "isAvailable": { "type": "boolean" },
          "isPromoted": { "type": "boolean" },
          "loyaltyPoints": { "type": "number" }
        }
      },
      "description": "Menu products"
    }
  }
}
