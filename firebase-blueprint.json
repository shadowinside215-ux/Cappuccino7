{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and loyalty data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "points": { "type": "number" },
        "coffeeCount": { "type": "number" },
        "itemLoyalty": { "type": "object" },
        "isAdmin": { "type": "boolean" },
        "isAnonymous": { "type": "boolean" },
        "isWaiter": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "points"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "delivered", "cancelled"] },
        "deliveryType": { "type": "string", "enum": ["delivery", "pickup", "dine-in", "takeaway"] },
        "tableZone": { "type": "string", "enum": ["A", "B"] },
        "tableArea": { "type": "string", "enum": ["Inside", "Outside"] },
        "tableNumber": { "type": "string" },
        "fullTableLabel": { "type": "string" },
        "waiterId": { "type": "string" },
        "waiterName": { "type": "string" },
        "waiterStatus": { "type": "string", "enum": ["New", "Accepted", "Preparing", "Ready", "Served"] },
        "prepTime": { "type": "number" },
        "estimatedReadyAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "deliveryType", "prepTime"]
    },
    "WaiterRequest": {
      "title": "Waiter Request",
      "description": "Call waiter notification",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "tableZone": { "type": "string" },
        "tableArea": { "type": "string" },
        "tableNumber": { "type": "string" },
        "fullTableLabel": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "accepted", "completed"] },
        "waiterId": { "type": "string" },
        "waiterName": { "type": "string" }
      },
      "required": ["clientId", "fullTableLabel", "status", "timestamp"]
    },
    "BrandSettings": {
      "title": "Brand Settings",
      "description": "Global application branding",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "heroImageUrl": { "type": "string" },
        "cartBgUrl": { "type": "string" },
        "ordersBgUrl": { "type": "string" },
        "profileBgUrl": { "type": "string" },
        "loginBgUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and loyalty points"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer food and drink orders"
    },
    "/settings/brand": {
      "schema": "BrandSettings",
      "description": "Global brand configuration"
    },
    "/waiterRequests/{requestId}": {
      "schema": "WaiterRequest",
      "description": "Dine-in client assistance requests"
    },
    "/admins/{adminId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        }
      },
      "description": "List of admin UIDs"
    },
    "/waiters/{waiterId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        }
      },
      "description": "List of waiter UIDs"
    },
    "/categories/{categoryId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "order": { "type": "number" }
        }
      },
      "description": "Menu categories"
    },
    "/products/{productId}": {
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "imageUrl": { "type": "string" },
          "categoryId": { "type": "string" },
          "isAvailable": { "type": "boolean" },
          "isPromoted": { "type": "boolean" },
          "loyaltyPoints": { "type": "number" }
        }
      },
      "description": "Menu products"
    },
    "/dailyRevenue/{date}": {
      "schema": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "orderCount": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Daily revenue tracking"
    },
    "/weeklyRevenue/{id}": {
      "schema": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "orderCount": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Weekly revenue tracking"
    },
    "/monthlyRevenue/{id}": {
      "schema": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "orderCount": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Monthly revenue tracking"
    },
    "/stats/{date}": {
      "schema": {
        "type": "object",
        "properties": {
          "revenue": { "type": "number" },
          "orders": { "type": "number" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Legacy daily statistics tracking"
    }
  }
}
