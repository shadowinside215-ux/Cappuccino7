{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Customer information including loyalty points.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "points": { "type": "number" },
        "coffeeCount": { "type": "number" },
        "itemLoyalty": { "type": "object" },
        "isAdmin": { "type": "boolean" },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "points"]
    },
    "Category": {
      "title": "Menu Category",
      "description": "Categories like Coffee, Drinks, Desserts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["name", "order"]
    },
    "Product": {
      "title": "Menu Item",
      "description": "Individual items in the menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "categoryId": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["name", "price", "categoryId", "isAvailable"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "Details of an order placed by a customer.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "ready", "delivered"] },
        "address": { "type": "string" },
        "location": { "type": "object" },
        "pointsEarned": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Settings": {
      "title": "App Settings",
      "description": "Global configuration like loyalty rules.",
      "type": "object",
      "properties": {
        "pointsRate": { "type": "number" },
        "rewardThreshold": { "type": "number" }
      },
      "required": ["pointsRate", "rewardThreshold"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Menu categories."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Menu items."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "settings/global": {
      "schema": "Settings",
      "description": "Global app settings."
    },
    "settings/brand": {
      "schema": {
        "title": "Brand Settings",
        "type": "object",
        "properties": {
          "logoUrl": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["logoUrl"]
      },
      "description": "App logo and branding settings."
    },
    "admins/{adminId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Admin users list."
    }
  }
}
