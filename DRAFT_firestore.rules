rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.points is number && data.points >= 0 &&
             data.isAdmin is boolean &&
             data.keys().hasAll(['uid', 'email', 'points', 'isAdmin']) && 
             data.keys().size() == 4;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 1000 &&
             data.categoryId is string &&
             data.isAvailable is boolean &&
             data.keys().hasAll(['name', 'price', 'description', 'categoryId', 'isAvailable']) &&
             data.keys().size() == 5;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'preparing', 'ready', 'delivered'] &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0 &&
             data.createdAt is timestamp &&
             (data.status == 'pending' || isAdmin()); // Customers can only create pending orders
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().points == 0 && incoming().isAdmin == false;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']) || 
                      isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn(); // Allow everyone to check if they are admin
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']) || 
                    (isOwner(existing().userId) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled');
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
